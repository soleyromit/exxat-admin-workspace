# Vite/SPA app in PCE — not part of the Next.js build, causes pages-router conflicts
apps/pce/admin/src/

# Nothing under apps/pce/admin/components/ belongs here: it is all tracked source
# reachable from the Next graph. A `react-router-dom` import is not grounds to
# ignore a file — next.config.ts aliases that specifier to lib/react-router-compat.tsx.
