#!/bin/bash
# Workspace pre-commit hook. Tracked under scripts/git-hooks/ and
# symlinked into .git/hooks/pre-commit by scripts/install-hooks.sh.
#
# Runs in ~5-8 seconds. Gates + soft warns + digest regen:
#
#   1. architecture-audit --strict   (BLOCK on wiring errors)
#   2. backlink-audit --strict       (BLOCK on missing citations)
#   3. staleness-check               (WARN only)
#   4. ds-globals-audit              (BLOCK — globals.css conformance)
#   4d. ds-adoption-audit            (BLOCK — organism name collisions)
#   4e. ds-adoption touch-gate       (BLOCK — migration WARNs in staged files)
#   5. practices-audit staleness     (WARN only)
#   6. generate-digest
#
# Bypass:  git commit --no-verify   (use sparingly)

set -e

cd "$(git rev-parse --show-toplevel)"

# Skip on merge commits — they have their own dynamics
if [ -f .git/MERGE_HEAD ]; then
  echo "↳ pre-commit: merge commit detected, skipping audits"
  exit 0
fi

# Skip if no scripts dir (e.g., during a bisect with old commits)
if [ ! -d scripts ]; then
  exit 0
fi

YELLOW='\033[33m'
GREEN='\033[32m'
RED='\033[31m'
RESET='\033[0m'

echo "↳ pre-commit (workspace audits + digest)"
echo

# 0. DS snapshot regen — silent step; skip gracefully if package not installed
printf "  [0/6] ds-snapshot regen  ... "
if python3 scripts/regen-ds-snapshot.py > /tmp/pre-commit-ds-snapshot.log 2>&1; then
  # Stage the snapshot if it changed (so the updated snapshot rides in the commit)
  if ! git diff --quiet docs/watch/ds-snapshot.json 2>/dev/null; then
    git add docs/watch/ds-snapshot.json
    printf "${GREEN}refreshed${RESET} (staged docs/watch/ds-snapshot.json)\n"
  else
    printf "${GREEN}pass${RESET}\n"
  fi
else
  exit_code=$?
  if [ "$exit_code" = "2" ]; then
    # Exit code 2 = package not installed; skip without blocking
    printf "${YELLOW}skip${RESET} (@exxatdesignux/ui not installed — run pnpm install)\n"
  else
    # Unexpected error — warn but do not block the commit
    printf "${YELLOW}warn${RESET} (regen failed — see /tmp/pre-commit-ds-snapshot.log)\n"
  fi
fi

# 1. Architecture audit — auto-fix skill frontmatter, then block on remaining gaps
printf "  [1/6] architecture-audit ... "
python3 scripts/architecture-audit.py --fix > /tmp/pre-commit-arch-fix.log 2>&1
if grep -q "\[fix\] patched" /tmp/pre-commit-arch-fix.log 2>/dev/null; then
  git add -u .claude/skills/ 2>/dev/null || true
fi
if python3 scripts/architecture-audit.py --strict > /tmp/pre-commit-arch.log 2>&1; then
  printf "${GREEN}pass${RESET}\n"
else
  printf "${RED}FAIL${RESET} — blocking commit\n\n"
  cat /tmp/pre-commit-arch.log
  echo
  echo "Fix wiring gaps above, or bypass with: git commit --no-verify"
  exit 1
fi

# 2. Backlink audit — citations must be tight
printf "  [2/6] backlink-audit     ... "
if python3 scripts/backlink-audit.py --strict > /tmp/pre-commit-backlink.log 2>&1; then
  printf "${GREEN}pass${RESET}\n"
else
  printf "${RED}FAIL${RESET} — blocking commit\n\n"
  cat /tmp/pre-commit-backlink.log
  echo
  echo "Add missing citations, or bypass with: git commit --no-verify"
  exit 1
fi

# 3. Staleness — soft warn only
printf "  [3/6] staleness-check    ... "
if python3 scripts/staleness-check.py > /tmp/pre-commit-stale.log 2>&1; then
  if grep -q "^Checked.*Found" /tmp/pre-commit-stale.log; then
    gaps=$(grep -E "^Checked.*Found ([0-9]+)" /tmp/pre-commit-stale.log | sed -E 's/.*Found ([0-9]+).*/\1/')
    printf "${YELLOW}%s warning(s)${RESET} (not blocking)\n" "$gaps"
  else
    printf "${GREEN}pass${RESET}\n"
  fi
fi

# 4. DS-012 globals conformance — BLOCKING (every admin app must have DS overrides)
printf "  [4/6] ds-globals-audit    ... "
if python3 scripts/ds-globals-audit.py --strict > /tmp/pre-commit-ds-globals.log 2>&1; then
  printf "${GREEN}pass${RESET}\n"
else
  printf "${RED}FAIL${RESET} — blocking commit\n\n"
  cat /tmp/pre-commit-ds-globals.log
  echo
  echo "Fix:  python3 scripts/ds-globals-audit.py --fix"
  echo "Or:   copy missing blocks from docs/foundations/admin-globals-template.css"
  echo "Bypass: git commit --no-verify"
  exit 1
fi

# 4b. Brand-presence audit — WARN ONLY (existing pages have known gaps)
printf "       brand-presence    ... "
if python3 scripts/brand-presence-audit.py > /tmp/pre-commit-brand.log 2>&1; then
  brandless=$(grep -oE "[0-9]+ brandless" /tmp/pre-commit-brand.log | head -1 | grep -oE "[0-9]+" || echo "0")
  if [ "$brandless" = "0" ]; then
    printf "${GREEN}clean${RESET}\n"
  else
    printf "${YELLOW}%s brandless pages${RESET} (warn — see DS-018)\n" "$brandless"
  fi
fi

# 4c. Dead-link audit — DEMOTED 2026-05-11 (architect-runs/2026-05-11-baseline.md
#     PROPOSED-RETIRE-1). Caught 0 real bugs this session; known false-positive
#     bias (doesn't trace variable assignments — blind-spots row #11). Script
#     remains runnable as a manual probe: `python3 scripts/dead-link-audit.py`.

# 4d. DS-adoption audit — PHASE 2 (block on every blocking rule)
#
# Three-phase rollout (2026-05-11):
#   Phase 0 (shipped, then promoted): WARN only.
#   Phase 1 (promoted 2026-05-11 after PCE bulk migration landed):
#     BLOCK on NEW organism-name-collision. exam-mgmt grandfathered.
#   Phase 2 (current, promoted 2026-05-11 after exam-mgmt sweep cleared
#     all 3 raw-table sites + 21 card-imposters + grandfathered files):
#     Block on every blocking rule via plain --strict. Workspace is 0 block
#     across all 4 apps. New violations introduced by any commit will fail.
#
# Promote / demote by adding --strict-rules to filter.
printf "       ds-adoption       ... "
if python3 scripts/ds-adoption-audit.py --strict > /tmp/pre-commit-ds-adoption.log 2>&1; then
  blocks=$(grep -oE "[0-9]+ blocking" /tmp/pre-commit-ds-adoption.log | head -1 | grep -oE "[0-9]+" || echo "0")
  warns=$(grep -oE "[0-9]+ warning" /tmp/pre-commit-ds-adoption.log | head -1 | grep -oE "[0-9]+" || echo "0")
  if [ "$blocks" = "0" ] && [ "$warns" = "0" ]; then
    printf "${GREEN}clean${RESET}\n"
  else
    printf "${GREEN}pass${RESET} (%s warn + %s tracked block — phase-1, non-strict rules deferred)\n" "$warns" "$blocks"
  fi
else
  printf "${RED}FAIL${RESET} — new file matches DS organism name\n\n"
  cat /tmp/pre-commit-ds-adoption.log
  echo
  echo "Fix:    consult docs/governance/ds-adoption.md, then either"
  echo "        - import / vendor the DS organism, or"
  echo "        - rename + add to 'Documented hand-rolls' in the registry"
  echo "Bypass: git commit --no-verify"
  exit 1
fi

# 4e. DS adoption touch-gate — BLOCK on migration-target WARNs in staged files
#
# For every .tsx/.ts file staged under apps/, promotes these WARN rules to BLOCK:
#   raw-html-button, hand-rolled-export-drawer, color-mix-contrast-risk,
#   vendored-datatable, missing-list-page-template, card-shape-masquerade,
#   hand-rolled-status-badge.
#
# Existing violations in UN-staged files are not checked here — they're tracked
# in the per-product ds-sweep-*.md backlogs. Staging a file forces migration.
# Skip the gate with: git commit --no-verify  (use sparingly).
printf "       ds-touch-gate      ... "
staged_tsx=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(tsx|ts)$' | grep '^apps/' || true)
if [ -z "$staged_tsx" ]; then
  printf "${GREEN}skip${RESET} (no staged app .tsx/.ts)\n"
else
  if python3 scripts/ds-adoption-audit.py --touched-files "$staged_tsx" --strict > /tmp/pre-commit-ds-touch.log 2>&1; then
    printf "${GREEN}pass${RESET}\n"
  else
    printf "${RED}FAIL${RESET} — staged file has DS migration violation\n\n"
    cat /tmp/pre-commit-ds-touch.log
    echo
    echo "Fix the violations above before committing, or bypass with: git commit --no-verify"
    exit 1
  fi
fi

# 4f. Context budget audit — WARN only (agent prompts + CLAUDE.md lazy-load discipline)
printf "       context-budget    ... "
if python3 scripts/context-budget-audit.py > /tmp/pre-commit-context.log 2>&1; then
  result=$(cat /tmp/pre-commit-context.log)
  if [ "$result" = "pass" ]; then
    printf "${GREEN}pass${RESET}\n"
  else
    gaps=$(grep -c "^\s*\[" /tmp/pre-commit-context.log || echo "0")
    printf "${YELLOW}%s gap(s)${RESET} (warn — not blocking)\n" "$gaps"
    cat /tmp/pre-commit-context.log | sed 's/^/         /'
  fi
fi

# 5. Practices-audit staleness — soft warn at 60d, never block
printf "  [5/6] practices-staleness ... "
if python3 scripts/practices-audit-staleness.py > /tmp/pre-commit-practices.log 2>&1; then
  msg=$(cat /tmp/pre-commit-practices.log)
  if [[ "$msg" == *"reminder"* ]]; then
    printf "${YELLOW}reminder${RESET} (run /practices-audit when convenient)\n"
  else
    printf "${GREEN}fresh${RESET}\n"
  fi
else
  printf "${YELLOW}STALE${RESET} (not blocking — run /practices-audit)\n"
  cat /tmp/pre-commit-practices.log | sed 's/^/      /'
fi

# 6. Regenerate digest and stage it if changed
printf "  [6/6] regenerate digest  ... "
python3 scripts/generate-digest.py > /tmp/pre-commit-digest.log 2>&1
if [ -f docs/digest/latest.md ]; then
  # Stage latest.md only if it actually changed (avoids no-op churn)
  if ! git diff --quiet docs/digest/latest.md 2>/dev/null; then
    git add docs/digest/latest.md
    printf "${GREEN}refreshed${RESET} (staged docs/digest/latest.md)\n"
  else
    printf "${GREEN}up-to-date${RESET}\n"
  fi
else
  printf "${YELLOW}skipped${RESET} (no digest output)\n"
fi

echo
echo "✓ all checks pass — proceeding with commit"
exit 0
