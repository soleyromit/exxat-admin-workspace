{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": false,
  "buildCommand": "echo 'static site, no build needed'",
  "outputDirectory": ".",
  "installCommand": "echo 'no install needed'",
  "framework": null,
  "ignoreCommand": "case $VERCEL_GIT_COMMIT_REF in dev|main) exit 1;; esac; P=$VERCEL_GIT_PREVIOUS_SHA; [ -z \"$P\" ] && exit 1; git cat-file -e $P 2>/dev/null || exit 1; git diff --quiet $P HEAD -- apps/pce/prototype/ && exit 0 || exit 1",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}
