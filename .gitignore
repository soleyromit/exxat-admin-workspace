node_modules/
.next/
.turbo/
*.tsbuildinfo
.env*.local
.DS_Store
dist/
/Admin/
/Student/
.vercel
.superpowers/
/awesome-design-md/

# Python bytecode caches (e.g. from .claude/hooks/*.py)
__pycache__/
*.pyc
*.pyo

# Digest — date-stamped files regenerate from current workspace state.
# Track latest.md + README only.
docs/digest/*.md
!docs/digest/latest.md
!docs/digest/README.md

# Local-only canvas (regenerated on demand by /morning-canvas)
.review/

# Visual-check screenshots (generated by tools/visual-check/run.mjs)
tools/visual-check/screenshots/

# DS visual-diff runtime marker (written by visual-diff.mjs)
.claude/state/


# Claude Code agent worktrees (embedded git repos — never commit)
.claude/worktrees/

# app-level pnpm symlinks (not caught by node_modules/ dir rule)
apps/*/*/node_modules
