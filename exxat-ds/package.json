{
  "name": "exxat-ds-workspace",
  "version": "0.0.0",
  "private": true,
  "description": "Exxat Design System monorepo: shared UI (@exxat-ds/ui), apps under apps/*. Setup: README Quick Start — brew install node gh && gh api … | bash (macOS) or install Node+gh then same pipeline.",
  "keywords": [
    "exxat",
    "design-system",
    "monorepo",
    "pnpm",
    "turborepo",
    "nextjs",
    "apps",
    "bootstrap",
    "setup"
  ],
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "bootstrap": "bash scripts/bootstrap.sh",
    "dev": "pnpm --filter apps/* dev",
    "dev:web": "pnpm --filter @exxat-ds/web dev",
    "build": "pnpm --filter apps/* build",
    "lint": "pnpm --filter apps/* lint",
    "typecheck": "pnpm --filter apps/* typecheck",
    "format": "prettier --write \"**/*.{ts,tsx}\""
  },
  "devDependencies": {
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  }
}
