# Logo.dev publishable key — get one at https://www.logo.dev/
# Required for company/organisation logos to load in production.
# Add to Vercel: Project Settings → Environment Variables → VITE_LOGO_DEV_TOKEN
VITE_LOGO_DEV_TOKEN=your_logo_dev_publishable_key

# MapTiler API key — get one at https://cloud.maptiler.com/account/keys/
# Used for address map in schedule detail (OpenMapTiles streets style)
VITE_MAPTILER_API_KEY=your_maptiler_api_key
